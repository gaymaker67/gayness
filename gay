function Get-KeyName {
    param([string]$Path)
    return ($Path -split '\\')[-1]
}

function Check-Key {
    param([string]$Path)

    $name = Get-KeyName $Path

    if (-not (Test-Path $Path)) {
        Write-Host "$name -> NOT FOUND ❌"
        return
    }

    try {
        $props = Get-ItemProperty $Path -ErrorAction Stop

        $values = $props.PSObject.Properties |
            Where-Object { $_.Name -notlike "PS*" }

        $nonDefault = $values | Where-Object { $_.Name -ne "(default)" }

        if ($nonDefault.Count -eq 0) {
            Write-Host "$name -> OK ✔ (EMPTY)" -ForegroundColor Green
        } else {

            $valueText = ($nonDefault | ForEach-Object {
                "$($_.Name)=$($_.Value)"
            }) -join ", "

            Write-Host "$name -> NOT OK ❌ [$valueText]" -ForegroundColor Red
        }

    } catch {
        Write-Host "$name -> NOT OK ❌" -ForegroundColor Red
    }
